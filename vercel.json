{
  "redirects": [
    { "source": "/specimen", "destination": "/business/specimen", "statusCode": 301 },
    { "source": "/history", "destination": "/history/specimen", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/business/:path*", "destination": "/index.html" },
    { "source": "/history/:path*", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" }
  ]
}
